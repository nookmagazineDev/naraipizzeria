# ── ตัวอย่างไฟล์เก็บค่าเชื่อมต่อ SQL Server ──
# 1) คัดลอกไฟล์นี้เป็น  db.env.ps1  (ไฟล์จริงจะไม่ขึ้น git)
# 2) ใส่รหัสผ่านจริง
# 3) start-narai.ps1 จะ . (dot-source) ไฟล์นี้ให้อัตโนมัติ

$env:DB_SERVER   = 'localhost'      # named instance ใช้ 'localhost\SQLEXPRESS' (แล้วลบ DB_PORT)
$env:DB_PORT     = '1433'
$env:DB_NAME     = 'NaraiPos'
$env:DB_USER     = 'SA'
$env:DB_PASSWORD = 'ใส่รหัสจริงตรงนี้'
